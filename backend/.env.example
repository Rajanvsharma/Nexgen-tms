# Supabase PostgreSQL (get both URLs from Supabase → Project Settings → Database)
DATABASE_URL="postgresql://postgres.xxxx:PASSWORD@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.xxxx:PASSWORD@aws-0-us-east-1.pooler.supabase.com:5432/postgres"

JWT_ACCESS_SECRET="change-this-to-a-random-secret-min-32-chars"
JWT_REFRESH_SECRET="change-this-to-another-random-secret-min-32-chars"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"
PORT=4000
NODE_ENV=production
FRONTEND_URL="https://your-frontend.vercel.app"
ANTHROPIC_API_KEY="sk-ant-api03-..."
